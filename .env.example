# ============================================================
# luggage-tag 环境变量配置
# 复制本文件为 .env 并按需修改：cp .env.example .env
# ============================================================

# ---- 服务绑定 ----
# 服务监听地址，默认仅本机访问；局域网部署改为 0.0.0.0
LUGGAGE_TAG_HOST=127.0.0.1
# 服务端口（默认 3001）
PORT=3001

# ---- 安全 / 认证 ----
# Super Admin 密码（不设置则使用默认 admin123，生产环境务必修改）
SUPER_ADMIN_PASSWORD=
# 兼容旧版环境变量（与 SUPER_ADMIN_PASSWORD 等效，优先取前者）
LUGGAGE_TAG_STAFF_PASSWORD=
# 强制 HTTPS Cookie（部署在 HTTPS 反向代理后设为 true）
LUGGAGE_TAG_COOKIE_SECURE=false
# 信任反向代理 X-Forwarded-* 头（部署在 nginx/Caddy 后设为 true）
LUGGAGE_TAG_TRUST_PROXY=false
# CORS 允许的额外来源，逗号分隔（默认自动放通本机/局域网）
LUGGAGE_TAG_ALLOW_ORIGIN=
# 公网绑定时允许使用默认密码（仅测试用，生产勿启用）
LUGGAGE_TAG_ALLOW_DEFAULT_PASSWORD_ON_PUBLIC_HOST=false

# ---- 登录限流 ----
# 注意：限流计数器存储在进程内存中，重启服务后会清零。
# 如需持久化限流，请在反向代理层（nginx/Caddy）配置 rate limit。
# 连续失败次数上限（默认 5）
LUGGAGE_TAG_LOGIN_MAX_FAILURES=5
# 锁定时间（毫秒，默认 300000 = 5 分钟）
LUGGAGE_TAG_LOGIN_LOCK_MS=300000

# ---- 数据目录 ----
# 数据库 / 备份 / 导出的根目录（默认为项目根目录下的 data/）
LUGGAGE_TAG_DATA_DIR=

# ---- 备份 ----
# 自动备份间隔（毫秒，默认 21600000 = 6 小时）
LUGGAGE_TAG_BACKUP_INTERVAL_MS=21600000
# 备份保留数量（默认 24）
LUGGAGE_TAG_BACKUP_RETENTION=24

# ---- Token / 审计清理 ----
# Token 过期清理间隔（毫秒，默认 3600000 = 1 小时）
LUGGAGE_TAG_TOKEN_CLEANUP_INTERVAL_MS=3600000
# 审计日志保留条数（默认 5000）
LUGGAGE_TAG_AUDIT_RETENTION=5000
# 审计日志清理间隔（毫秒，默认等于 TOKEN_CLEANUP_INTERVAL_MS）
LUGGAGE_TAG_AUDIT_CLEANUP_INTERVAL_MS=3600000

# ---- 导出文件清理 ----
# 导出文件清理间隔（毫秒，默认 86400000 = 24 小时）
LUGGAGE_TAG_EXPORT_CLEANUP_INTERVAL_MS=86400000
# 导出文件最小保留时间（毫秒，默认 604800000 = 7 天）
LUGGAGE_TAG_EXPORT_CLEANUP_MIN_AGE_MS=604800000

# ---- 品牌 Logo ----
# 自定义 Logo 路径（默认查找 public/brand-logo.png 或 .svg）
LUGGAGE_TAG_BRAND_LOGO_PATH=

# ---- 开发 / 生产 ----
# 设置为 production 时启用生产模式（静态资源服务、CSP 严格模式等）
NODE_ENV=development
# Vite 前端 API 代理地址（开发模式默认 http://<hostname>:3001）
VITE_API_BASE=

# ---- 注意 ----
# node:sqlite 为 Node.js 实验性 API，需要 Node >= 22.5.0
# 部署前请确认 Node 版本：node --version
