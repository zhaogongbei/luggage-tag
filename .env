# ============================================================
# luggage-tag 生产环境配置
# ============================================================

# ---- 服务绑定 ----
# 本机监听，由 OpenResty 反向代理
LUGGAGE_TAG_HOST=127.0.0.1
PORT=3001

# ---- 环境 ----
NODE_ENV=production

# ---- 安全 / 认证 ----
# ⚠️ 务必修改默认密码
SUPER_ADMIN_PASSWORD=your_secure_password_here

# 信任反向代理头（OpenResty 会传递真实 IP 和协议）
LUGGAGE_TAG_TRUST_PROXY=true

# HTTPS Cookie（部署在 HTTPS 域名后）
LUGGAGE_TAG_COOKIE_SECURE=true

# CORS 允许的域名
LUGGAGE_TAG_ALLOW_ORIGIN=https://tag.ycgg.cc.cd

# ---- 部署模式 ----
# private: 仅员工登录后可用
# invite: 需要邀请码访问定制页
# public: 定制页公开访问
# maintenance: 维护模式
LUGGAGE_TAG_DEPLOY_MODE=public

# ---- 邀请码（如果使用 invite 模式）----
LUGGAGE_TAG_INVITE_CODE=

# ---- 数据目录 ----
# 留空则使用项目根目录下的 data/
LUGGAGE_TAG_DATA_DIR=

# ---- 备份 ----
# 6 小时自动备份一次
LUGGAGE_TAG_BACKUP_INTERVAL_MS=21600000
# 保留最近 24 个备份
LUGGAGE_TAG_BACKUP_RETENTION=24
