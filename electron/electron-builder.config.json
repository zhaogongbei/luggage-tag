{
  "appId": "com.ycgg.luggagetag",
  "directories": {
    "buildResources": "resources",
    "output": "dist"
  },
  "files": [
    "assets/**/*",
    "build/**/*",
    "capacitor.config.*",
    "app/**/*"
  ],
  "extraResources": [
    {
      "from": "local-server",
      "to": "local-server",
      "filter": [
        "**/*"
      ]
    }
  ],
  "win": {
    "target": "portable"
  },
  "asar": false
}
